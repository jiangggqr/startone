# demo: deterministic local judging path; real: server-side GPT-5.6 calls.
STARTFRAME_MODE=demo
STARTFRAME_HOST=127.0.0.1
STARTFRAME_PORT=8000
STARTFRAME_DATABASE_PATH=instance/startframe.sqlite3
STARTFRAME_UPLOAD_DIR=instance/uploads
STARTFRAME_MAX_FILE_MB=20
STARTFRAME_MAX_FILES=5
STARTFRAME_MAX_SESSIONS_PER_WORKSPACE=20
STARTFRAME_MAX_SOURCES_PER_WORKSPACE=50
STARTFRAME_SECURE_COOKIES=false
STARTFRAME_OPENAI_MODEL=gpt-5.6
STARTFRAME_OPENAI_TIMEOUT_SECONDS=45

# Required only in real mode. Never expose this value in browser code or commits.
OPENAI_API_KEY=
