# demo：完全确定性的本地演示；real：后续里程碑启用真实 GPT-5.6 调用。
STARTFRAME_MODE=demo
STARTFRAME_HOST=127.0.0.1
STARTFRAME_PORT=8000
STARTFRAME_DATABASE_PATH=instance/startframe.sqlite3
STARTFRAME_UPLOAD_DIR=instance/uploads
STARTFRAME_MAX_FILE_MB=20
STARTFRAME_MAX_FILES=5
STARTFRAME_SECURE_COOKIES=false

# Milestone 0 不会读取或调用 OpenAI。真实模型功能加入后只从服务端读取此变量。
OPENAI_API_KEY=
